<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/wondaywall_widget_more_row_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:gravity="center_vertical"
    android:minHeight="32dp"
    android:orientation="horizontal"
    android:paddingHorizontal="8dp"
    android:paddingVertical="5dp">

    <TextView
        android:id="@+id/wondaywall_widget_more_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="その他の予定・ニュース"
        android:textColor="#FF1B1B1F"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/wondaywall_widget_more_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text=">"
        android:textColor="#FF535F70"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
