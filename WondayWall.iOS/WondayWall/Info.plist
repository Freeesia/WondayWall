<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <dict>
        <key>CFBundleDevelopmentRegion</key>
        <string>$(DEVELOPMENT_LANGUAGE)</string>
        <key>CFBundleExecutable</key>
        <string>$(EXECUTABLE_NAME)</string>
        <key>CFBundleIdentifier</key>
        <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
        <key>CFBundleInfoDictionaryVersion</key>
        <string>6.0</string>
        <key>CFBundleName</key>
        <string>$(PRODUCT_NAME)</string>
        <key>CFBundlePackageType</key>
        <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
        <key>CFBundleShortVersionString</key>
        <string>$(MARKETING_VERSION)</string>
        <key>CFBundleVersion</key>
        <string>$(CURRENT_PROJECT_VERSION)</string>
        <!-- Welcome 画面などで現在のビルド設定に対応した appiconset を参照する -->
        <key>WondayWallAppIconAssetName</key>
        <string>$(ASSETCATALOG_COMPILER_APPICON_NAME)</string>
        <!-- 標準的なHTTPS通信のみを使うため、TestFlightアップロード後の暗号化確認を自動化する -->
        <key>ITSAppUsesNonExemptEncryption</key>
        <false />
        <!-- バックグラウンド処理タスクの許可 ID -->
        <key>BGTaskSchedulerPermittedIdentifiers</key>
        <array>
            <string>$(PRODUCT_BUNDLE_IDENTIFIER).generation</string>
            <!-- 明示的なユーザーリクエスト用の continued processing task -->
            <string>$(PRODUCT_BUNDLE_IDENTIFIER).manual.*</string>
        </array>
        <!-- バックグラウンドモード -->
        <key>UIBackgroundModes</key>
        <array>
            <string>processing</string>
            <string>fetch</string>
        </array>
        <!-- カレンダーアクセス権限（iOS 17+: フルアクセス） -->
        <key>NSCalendarsFullAccessUsageDescription</key>
        <string>壁紙生成の文脈作成のために、カレンダーの予定タイトル・日時・場所・メモを読み取ります。予定の作成・編集・削除は行いません。</string>
        <!-- iOS 16 以前向けカレンダーアクセス権限 -->
        <key>NSCalendarsUsageDescription</key>
        <string>壁紙生成の文脈作成のために、カレンダーの予定タイトル・日時・場所・メモを読み取ります。予定の作成・編集・削除は行いません。</string>
        <!-- 写真ライブラリへのフルアクセス権限（WondayWall アルバム管理に必要） -->
        <key>NSPhotoLibraryUsageDescription</key>
        <string>生成した壁紙を専用アルバム「WondayWall」に追加・管理するために使用します。最新の壁紙のみアルバムに残し、古い壁紙はアルバムから外します（削除しません）。</string>
        <key>UIApplicationSceneManifest</key>
        <dict>
            <key>UIApplicationSupportsMultipleScenes</key>
            <false />
            <key>UISceneConfigurations</key>
            <dict />
        </dict>
        <key>UILaunchScreen</key>
        <dict />
        <key>UISupportedInterfaceOrientations</key>
        <array>
            <string>UIInterfaceOrientationPortrait</string>
        </array>
    </dict>
</plist>
