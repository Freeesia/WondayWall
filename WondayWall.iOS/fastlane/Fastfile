require "base64"
require "fileutils"
require "open3"
require "shellwords"
require "tmpdir"
require "xcodeproj"

opt_out_usage
default_platform(:ios)

IOS_PROJECT_DIR = File.expand_path("..", __dir__)
PROJECT_PATH = File.join(IOS_PROJECT_DIR, "WondayWall.xcodeproj")
OUTPUT_DIR = File.join(IOS_PROJECT_DIR, "build/testflight")
IPA_NAME = "WondayWallPreview.ipa"
DEFAULT_TEAM_ID = "KDJQJM26Y7"
DEFAULT_APP_IDENTIFIER = "com.studiofreesia.wondaywall.preview"
DEFAULT_PREVIEW_TESTER_GROUP = "PR Preview Testers"

def required_env(name)
  value = ENV[name].to_s
  UI.user_error!("Missing required environment variable: #{name}") if value.empty?
  value
end

def env_or_default(name, default)
  value = ENV[name].to_s.strip
  value.empty? ? default : value
end

def team_id
  env_or_default("TEAM_ID", DEFAULT_TEAM_ID)
end

def app_identifier
  env_or_default("APP_IDENTIFIER", DEFAULT_APP_IDENTIFIER)
end

def tester_group
  env_or_default("PREVIEW_TESTER_GROUP", DEFAULT_PREVIEW_TESTER_GROUP)
end

def run_command(label, *command)
  UI.message(label)
  stdout, stderr, status = Open3.capture3(*command)
  unless status.success?
    UI.error(stdout.strip) unless stdout.strip.empty?
    UI.error(stderr.strip) unless stderr.strip.empty?
    UI.user_error!("#{label} failed")
  end
  stdout
end

def write_base64_secret(env_name, path)
  File.binwrite(path, Base64.decode64(required_env(env_name)))
end

def app_store_connect_key_content
  key_content = required_env("ASC_KEY_P8").strip.gsub("\\n", "\n")
  return key_content if key_content.include?("BEGIN PRIVATE KEY")

  decoded = Base64.decode64(key_content)
  return decoded if decoded.include?("BEGIN PRIVATE KEY")

  UI.user_error!("ASC_KEY_P8 must be raw .p8 content or base64 encoded .p8 content")
end

def setup_signing_assets
  signing_dir = Dir.mktmpdir("wondaywall-signing-")
  certificate_path = File.join(signing_dir, "appstore.p12")
  profile_path = File.join(signing_dir, "preview.mobileprovision")
  profile_plist_path = File.join(signing_dir, "preview-profile.plist")
  ENV["WONDAYWALL_CI_SIGNING_DIR"] = signing_dir

  write_base64_secret("APPSTORE_CERTIFICATE_BASE64", certificate_path)
  write_base64_secret("APPSTORE_PROVISIONING_PROFILE_BASE64", profile_path)

  run_id = ENV.fetch("GITHUB_RUN_ID", "local")
  keychain_name = "wondaywall-testflight-#{run_id}.keychain-db"
  keychain_path = File.expand_path("~/Library/Keychains/#{keychain_name}")
  keychain_password = required_env("KEYCHAIN_PASSWORD")
  original_keychains = run_command("Read original keychains", "security", "list-keychains", "-d", "user")
    .lines
    .map { |line| line.strip.delete('"') }
    .reject(&:empty?)
  # setup途中で失敗してもensureで必ず破棄できるよう、cleanup用の情報を先に保持する。
  ENV["WONDAYWALL_CI_KEYCHAIN_PATH"] = keychain_path
  ENV["WONDAYWALL_CI_ORIGINAL_KEYCHAINS"] = original_keychains.join(File::PATH_SEPARATOR)

  # CI用の一時keychainに証明書を閉じ込める。
  run_command("Create temporary keychain", "security", "create-keychain", "-p", keychain_password, keychain_name)
  run_command("Unlock temporary keychain", "security", "unlock-keychain", "-p", keychain_password, keychain_path)
  run_command("Configure temporary keychain timeout", "security", "set-keychain-settings", "-lut", "21600", keychain_path)
  run_command("Use temporary keychain", "security", "list-keychains", "-d", "user", "-s", keychain_path, *original_keychains)
  run_command(
    "Import App Store certificate",
    "security",
    "import",
    certificate_path,
    "-k",
    keychain_path,
    "-P",
    required_env("APPSTORE_CERTIFICATE_PASSWORD"),
    "-T",
    "/usr/bin/codesign",
    "-T",
    "/usr/bin/security"
  )
  run_command(
    "Allow codesign to use imported certificate",
    "security",
    "set-key-partition-list",
    "-S",
    "apple-tool:,apple:,codesign:",
    "-s",
    "-k",
    keychain_password,
    keychain_path
  )

  profile_plist = run_command("Decode provisioning profile", "security", "cms", "-D", "-i", profile_path)
  File.write(profile_plist_path, profile_plist)
  profile_uuid = run_command("Read provisioning profile UUID", "/usr/libexec/PlistBuddy", "-c", "Print UUID", profile_plist_path).strip
  profile_name = run_command("Read provisioning profile name", "/usr/libexec/PlistBuddy", "-c", "Print Name", profile_plist_path).strip
  profile_app_id = run_command(
    "Read provisioning profile app identifier",
    "/usr/libexec/PlistBuddy",
    "-c",
    "Print Entitlements:application-identifier",
    profile_plist_path
  ).strip
  profile_team_id = run_command(
    "Read provisioning profile team identifier",
    "/usr/libexec/PlistBuddy",
    "-c",
    "Print TeamIdentifier:0",
    profile_plist_path
  ).strip
  UI.user_error!("Provisioning profile is invalid: TeamIdentifier is missing or empty") if profile_team_id.empty?
  expected_profile_app_id = "#{team_id}.#{app_identifier}"
  if profile_team_id != team_id
    UI.user_error!("Provisioning profile team mismatch. expected=#{team_id} actual=#{profile_team_id}. Verify APPSTORE_PROVISIONING_PROFILE_BASE64 uses the correct Team ID profile.")
  end
  if profile_app_id != expected_profile_app_id
    UI.user_error!("Provisioning profile app mismatch. expected=#{expected_profile_app_id} actual=#{profile_app_id}. Verify APP_IDENTIFIER and regenerate the provisioning profile if needed.")
  end

  profile_destination = File.expand_path("~/Library/MobileDevice/Provisioning Profiles/#{profile_uuid}.mobileprovision")
  FileUtils.mkdir_p(File.dirname(profile_destination))
  FileUtils.cp(profile_path, profile_destination)
  ENV["WONDAYWALL_CI_PROFILE_PATH"] = profile_destination

  {
    keychain_path: keychain_path,
    profile_name: profile_name,
    profile_uuid: profile_uuid
  }
end

def cleanup_signing_assets
  keychain_path = ENV["WONDAYWALL_CI_KEYCHAIN_PATH"]
  original_keychains = ENV["WONDAYWALL_CI_ORIGINAL_KEYCHAINS"].to_s.split(File::PATH_SEPARATOR).reject(&:empty?)
  profile_path = ENV["WONDAYWALL_CI_PROFILE_PATH"]
  signing_dir = ENV["WONDAYWALL_CI_SIGNING_DIR"]

  Open3.capture3("security", "list-keychains", "-d", "user", "-s", *original_keychains) unless original_keychains.empty?
  Open3.capture3("security", "delete-keychain", keychain_path) if keychain_path && File.exist?(keychain_path)
  FileUtils.rm_f(profile_path) if profile_path
  FileUtils.rm_rf(signing_dir) if signing_dir
end

def manual_signing_xcargs(signing_assets, build_number)
  xcconfig_path = preview_xcconfig_path(build_number)
  [
    "-xcconfig #{Shellwords.escape(xcconfig_path)}",
    "OTHER_CODE_SIGN_FLAGS=#{Shellwords.escape("--keychain #{signing_assets[:keychain_path]}")}"
  ].join(" ")
end

def configure_app_target_signing(signing_assets)
  project = Xcodeproj::Project.open(PROJECT_PATH)
  target = project.targets.find { |project_target| project_target.name == "WondayWall" }
  UI.user_error!("Target WondayWall not found in #{PROJECT_PATH}") unless target

  release_config = target.build_configurations.find { |config| config.name == "Release" }
  UI.user_error!("Release configuration not found for target WondayWall") unless release_config

  build_settings = release_config.build_settings
  build_settings["CODE_SIGN_STYLE"] = "Manual"
  build_settings["CODE_SIGN_IDENTITY"] = "Apple Distribution"
  build_settings["DEVELOPMENT_TEAM"] = team_id
  build_settings["PROVISIONING_PROFILE_SPECIFIER"] = signing_assets[:profile_name]
  project.save
end

def preview_xcconfig_path(build_number)
  configured_path = ENV["PREVIEW_XCCONFIG_PATH"].to_s
  return File.expand_path(configured_path, IOS_PROJECT_DIR) unless configured_path.empty?

  FileUtils.mkdir_p(OUTPUT_DIR)
  path = File.join(OUTPUT_DIR, "Preview.ci.xcconfig")
  base_xcconfig_path = File.join(IOS_PROJECT_DIR, "Config/Preview.xcconfig")
  File.write(
    path,
    [
      "#include \"#{base_xcconfig_path}\"",
      "CURRENT_PROJECT_VERSION = #{build_number}"
    ].join("\n") + "\n"
  )
  path
end

platform :ios do
  desc "Build the preview app and upload it to TestFlight Internal Testing"
  lane :pr_testflight do
    build_number = ENV.fetch("PREVIEW_BUILD_NUMBER", ENV.fetch("GITHUB_RUN_NUMBER", "0"))
    UI.user_error!("PREVIEW_BUILD_NUMBER must not be 0") if build_number == "0"

    api_key = app_store_connect_api_key(
      key_id: required_env("ASC_KEY_ID"),
      issuer_id: required_env("ASC_ISSUER_ID"),
      key_content: app_store_connect_key_content,
      is_key_content_base64: false,
      duration: 1200,
      in_house: false
    )

    signing_assets = setup_signing_assets
    configure_app_target_signing(signing_assets)
    FileUtils.mkdir_p(OUTPUT_DIR)

    build_app(
      project: PROJECT_PATH,
      scheme: "WondayWall",
      configuration: "Release",
      clean: true,
      destination: "generic/platform=iOS",
      archive_path: File.join(OUTPUT_DIR, "WondayWallPreview.xcarchive"),
      output_directory: OUTPUT_DIR,
      output_name: IPA_NAME,
      export_method: "app-store",
      export_options: {
        method: "app-store",
        manageAppVersionAndBuildNumber: false,
        signingStyle: "manual",
        teamID: team_id,
        testFlightInternalTestingOnly: true,
        provisioningProfiles: {
          app_identifier => signing_assets[:profile_name]
        }
      },
      xcargs: manual_signing_xcargs(signing_assets, build_number)
    )

    changelog_lines = ["PR preview build"]
    pr_number = ENV["PREVIEW_PR_NUMBER"].to_s.strip
    changelog_lines << "PR: ##{pr_number}" unless pr_number.empty?
    changelog_lines += [
      "Commit: #{ENV.fetch("GITHUB_SHA", "local")}",
      "Build: #{build_number}"
    ]
    changelog = changelog_lines.join("\n")

    UI.message("Relying on App Store Connect automatic distribution for #{tester_group}")
    upload_to_testflight(
      api_key: api_key,
      app_identifier: app_identifier,
      ipa: File.join(OUTPUT_DIR, IPA_NAME),
      changelog: changelog,
      # 内部グループへの配信はApp Store Connectの自動配信設定に任せる。
      skip_submission: true,
      skip_waiting_for_build_processing: false,
      uses_non_exempt_encryption: false
    )
  ensure
    cleanup_signing_assets
  end
end
