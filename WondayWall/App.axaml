<Application
    x:Class="WondayWall.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sty="using:FluentAvalonia.Styling">
    <Application.Resources>
        <!--
            HeaderedContentControl を GroupBox 風にスタイリング（WPF GroupBox の代替）
            Header に太字タイトル、Content にカード背景付きコンテンツエリアを表示する
        -->
        <ControlTheme x:Key="{x:Type HeaderedContentControl}" TargetType="HeaderedContentControl">
            <Setter Property="Template">
                <ControlTemplate TargetType="HeaderedContentControl">
                    <Grid RowDefinitions="Auto,*">
                        <ContentPresenter
                            Grid.Row="0"
                            Margin="4,4,4,4"
                            Content="{TemplateBinding Header}"
                            FontWeight="Bold" />
                        <Border
                            Grid.Row="1"
                            Padding="8"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <ContentPresenter Content="{TemplateBinding Content}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </ControlTheme>
    </Application.Resources>
    <Application.Styles>
        <sty:FluentAvaloniaTheme />
        <StyleInclude Source="avares://WondayWall/Themes/Generic.axaml" />
    </Application.Styles>
</Application>
