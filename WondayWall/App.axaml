<Application
    x:Class="WondayWall.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sty="using:FluentAvalonia.Styling">
    <Application.Styles>
        <!-- FluentAvalonia テーマ: WinUI スタイルの色・ブラシ・コントロールを提供 -->
        <sty:FluentAvaloniaTheme PreferSystemTheme="True" PreferUserAccentColor="True" />
        <!-- DataGrid テーマ (正しいパスは .xaml) -->
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
        <!-- カスタムスタイル (Styles ルートなので StyleInclude を使用) -->
        <StyleInclude Source="avares://WondayWall/Themes/Generic.axaml" />
    </Application.Styles>
</Application>
