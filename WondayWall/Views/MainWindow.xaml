<ui:FluentWindow
    x:Class="WondayWall.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:WondayWall.ViewModels"
    Title="WondayWall"
    Width="900"
    Height="650"
    d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Default"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="WondayWall" Grid.Row="0" />

        <TabControl Grid.Row="1" Margin="8">
            <!--  Home Tab  -->
            <TabItem Header="ホーム">
                <ScrollViewer>
                    <StackPanel Margin="16">
                        <ui:CardControl Margin="0,0,0,12" Header="現在の壁紙">
                            <ui:CardControl.Icon>
                                <ui:SymbolIcon Symbol="Image24" />
                            </ui:CardControl.Icon>
                            <Image
                                MaxHeight="300"
                                Source="{Binding LastImagePreviewPath}"
                                Stretch="Uniform" />
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,12" Header="最終実行結果">
                            <ui:CardControl.Icon>
                                <ui:SymbolIcon Symbol="Info24" />
                            </ui:CardControl.Icon>
                            <TextBlock Text="{Binding LastResultMessage}" TextWrapping="Wrap" />
                        </ui:CardControl>

                        <ui:Button
                            Margin="0,0,0,8"
                            HorizontalAlignment="Left"
                            Appearance="Primary"
                            Command="{Binding GenerateCommand}"
                            Content="壁紙を今すぐ生成"
                            Icon="{ui:SymbolIcon Symbol=Wand24}" />

                        <ui:InfoBar
                            Margin="0,0,0,12"
                            IsClosable="False"
                            IsOpen="{Binding IsGenerating}"
                            Message="壁紙を生成中..."
                            Severity="Informational" />

                        <TextBlock
                            Margin="0,8,0,4"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="実行履歴" />
                        <ListView MaxHeight="200" ItemsSource="{Binding History}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn
                                        Width="160"
                                        DisplayMemberBinding="{Binding ExecutedAt, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}"
                                        Header="実行日時" />
                                    <GridViewColumn
                                        Width="60"
                                        DisplayMemberBinding="{Binding IsSuccess}"
                                        Header="成功" />
                                    <GridViewColumn
                                        Width="300"
                                        DisplayMemberBinding="{Binding ErrorSummary}"
                                        Header="メモ / エラー" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!--  Data Tab  -->
            <TabItem Header="データ">
                <ScrollViewer>
                    <StackPanel Margin="16">
                        <ui:CardControl Margin="0,0,0,12" Header="Googleカレンダー接続状態">
                            <ui:CardControl.Icon>
                                <ui:SymbolIcon Symbol="Calendar24" />
                            </ui:CardControl.Icon>
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8" Text="{Binding CalendarStatus}" />
                                <ui:Button
                                    Appearance="Secondary"
                                    Command="{Binding CheckConnectionCommand}"
                                    Content="接続確認" />
                            </StackPanel>
                        </ui:CardControl>

                        <TextBlock
                            Margin="0,8,0,4"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="直近のカレンダーイベント" />
                        <ListView
                            MaxHeight="160"
                            Margin="0,0,0,12"
                            ItemsSource="{Binding RecentEvents}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn
                                        Width="250"
                                        DisplayMemberBinding="{Binding Title}"
                                        Header="タイトル" />
                                    <GridViewColumn
                                        Width="160"
                                        DisplayMemberBinding="{Binding StartTime, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}"
                                        Header="開始日時" />
                                    <GridViewColumn
                                        Width="150"
                                        DisplayMemberBinding="{Binding Location}"
                                        Header="場所" />
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <ui:CardControl Margin="0,0,0,12" Header="ニュース取得">
                            <ui:CardControl.Icon>
                                <ui:SymbolIcon Symbol="News24" />
                            </ui:CardControl.Icon>
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8" Text="RSSフィードからニュースを取得します" />
                                <ui:Button
                                    Appearance="Secondary"
                                    Command="{Binding FetchNewsCommand}"
                                    Content="ニュース取得" />
                            </StackPanel>
                        </ui:CardControl>

                        <TextBlock
                            Margin="0,8,0,4"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="最新ニューストピック" />
                        <ListView MaxHeight="160" ItemsSource="{Binding RecentNews}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn
                                        Width="350"
                                        DisplayMemberBinding="{Binding Title}"
                                        Header="タイトル" />
                                    <GridViewColumn
                                        Width="160"
                                        DisplayMemberBinding="{Binding FetchedAt, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}"
                                        Header="取得日時" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!--  Settings Tab  -->
            <TabItem Header="設定">
                <ScrollViewer>
                    <StackPanel Margin="16">
                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="Google AI 設定" />
                        <Label Content="Google AI APIキー" />
                        <TextBox Margin="0,0,0,8" Text="{Binding AppConfig.GoogleAiApiKey, UpdateSourceTrigger=PropertyChanged}" />
                        <Label Content="Google AI モデル名" />
                        <TextBox Margin="0,0,0,8" Text="{Binding AppConfig.GoogleAiModelName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Margin="0,8,0,4"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="Googleカレンダー設定" />
                        <Label Content="OAuth クライアント ID" />
                        <TextBox Margin="0,0,0,8" Text="{Binding AppConfig.GoogleCalendarClientId, UpdateSourceTrigger=PropertyChanged}" />
                        <Label Content="OAuth クライアントシークレット" />
                        <TextBox Margin="0,0,0,8" Text="{Binding AppConfig.GoogleCalendarClientSecret, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Margin="0,8,0,4"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="画像設定" />
                        <Label Content="画像サイズ (例: 1920x1080)" />
                        <TextBox Margin="0,0,0,8" Text="{Binding AppConfig.ImageSize, UpdateSourceTrigger=PropertyChanged}" />
                        <Label Content="画像保存パス" />
                        <TextBox Margin="0,0,0,8" Text="{Binding AppConfig.ImageSavePath, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Margin="0,8,0,4"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="スケジュール設定" />
                        <Label Content="更新間隔 (時間)" />
                        <TextBox Margin="0,0,0,8" Text="{Binding AppConfig.UpdateIntervalHours, UpdateSourceTrigger=PropertyChanged}" />

                        <CheckBox
                            Margin="0,0,0,12"
                            Content="ログを有効にする"
                            IsChecked="{Binding AppConfig.EnableLogging}" />

                        <ui:CardControl Margin="0,0,0,12" Header="タスクスケジューラ">
                            <ui:CardControl.Icon>
                                <ui:SymbolIcon Symbol="Clock24" />
                            </ui:CardControl.Icon>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Center"
                                    Text="自動実行（更新間隔は上の設定を保存時に適用）" />
                                <CheckBox
                                    VerticalAlignment="Center"
                                    Command="{Binding ToggleTaskSchedulerCommand}"
                                    Content="有効"
                                    IsChecked="{Binding IsTaskSchedulerEnabled}" />
                            </StackPanel>
                        </ui:CardControl>

                        <ui:Button
                            HorizontalAlignment="Left"
                            Appearance="Primary"
                            Command="{Binding SaveCommand}"
                            Content="設定を保存" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</ui:FluentWindow>
