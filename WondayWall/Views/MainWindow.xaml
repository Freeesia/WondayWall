<ui:FluentWindow
    x:Class="WondayWall.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:WondayWall.ViewModels"
    xmlns:utils="clr-namespace:WondayWall.Utils"
    Title="WondayWall"
    Width="900"
    Height="650"
    d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Default"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <ui:FluentWindow.Resources>
        <utils:UrlToFaviconConverter x:Key="UrlToFaviconConverter" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="WondayWall" Grid.Row="0" />

        <TabControl Grid.Row="1" Margin="8">
            <!--  ホームタブ  -->
            <TabItem Header="ホーム">
                <ScrollViewer>
                    <StackPanel Margin="16">
                        <ui:CardControl Margin="0,0,0,12" Header="現在の壁紙">
                            <ui:CardControl.Icon>
                                <ui:SymbolIcon Symbol="Image24" />
                            </ui:CardControl.Icon>
                            <Image
                                MaxHeight="300"
                                Source="{Binding LastImagePreviewPath}"
                                Stretch="Uniform" />
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,12" Header="最終実行結果">
                            <ui:CardControl.Icon>
                                <ui:SymbolIcon Symbol="Info24" />
                            </ui:CardControl.Icon>
                            <TextBlock Text="{Binding LastResultMessage}" TextWrapping="Wrap" />
                        </ui:CardControl>

                        <ui:Button
                            Margin="0,0,0,8"
                            HorizontalAlignment="Left"
                            Appearance="Primary"
                            Command="{Binding GenerateCommand}"
                            Content="壁紙を今すぐ生成"
                            Icon="{ui:SymbolIcon Symbol=Wand24}" />

                        <ui:InfoBar
                            Margin="0,0,0,12"
                            IsClosable="False"
                            IsOpen="{Binding IsGenerating}"
                            Message="壁紙を生成中..."
                            Severity="Informational" />

                        <TextBlock
                            Margin="0,8,0,4"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="実行履歴" />
                        <ui:ListView MaxHeight="200" ItemsSource="{Binding History}">
                            <ui:ListView.View>
                                <ui:GridView>
                                    <GridViewColumn
                                        Width="160"
                                        DisplayMemberBinding="{Binding ExecutedAt, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}"
                                        Header="実行日時" />
                                    <GridViewColumn
                                        Width="60"
                                        DisplayMemberBinding="{Binding IsSuccess}"
                                        Header="成功" />
                                    <GridViewColumn
                                        Width="60"
                                        DisplayMemberBinding="{Binding UsedCalendarEvents.Count, FallbackValue=0}"
                                        Header="予定" />
                                    <GridViewColumn
                                        Width="60"
                                        DisplayMemberBinding="{Binding UsedNewsTopics.Count, FallbackValue=0}"
                                        Header="ニュース" />
                                    <GridViewColumn
                                        Width="200"
                                        DisplayMemberBinding="{Binding ErrorSummary}"
                                        Header="エラー" />
                                </ui:GridView>
                            </ui:ListView.View>
                        </ui:ListView>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!--  データタブ  -->
            <TabItem Header="データ">
                <ScrollViewer>
                    <StackPanel Margin="16">

                        <!--  カレンダーグループ  -->
                        <GroupBox Margin="0,0,0,12" Header="Googleカレンダー">
                            <StackPanel Margin="4">
                                <TextBlock Margin="0,0,0,8" Text="{Binding CalendarStatus}" />
                                <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                    <ui:Button
                                        Margin="0,0,8,0"
                                        Appearance="Secondary"
                                        Command="{Binding CheckConnectionCommand}"
                                        Content="接続確認" />
                                    <ui:Button
                                        Appearance="Secondary"
                                        Command="{Binding FetchAvailableCalendarsCommand}"
                                        Content="カレンダー一覧を取得" />
                                </StackPanel>

                                <TextBlock
                                    Margin="0,0,0,4"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Text="参照するカレンダー（「カレンダー一覧を取得」後に選択してください）" />
                                <ui:ListView
                                    MaxHeight="120"
                                    Margin="0,0,0,8"
                                    ItemsSource="{Binding AvailableCalendars}">
                                    <ui:ListView.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Summary}" IsChecked="{Binding IsSelected}" />
                                        </DataTemplate>
                                    </ui:ListView.ItemTemplate>
                                </ui:ListView>

                                <TextBlock
                                    Margin="0,4,0,4"
                                    FontWeight="SemiBold"
                                    Text="直近のカレンダーイベント" />
                                <ui:ListView
                                    MaxHeight="160"
                                    ItemsSource="{Binding RecentEvents}">
                                    <ui:ListView.View>
                                        <ui:GridView>
                                            <GridViewColumn
                                                Width="250"
                                                DisplayMemberBinding="{Binding Title}"
                                                Header="タイトル" />
                                            <GridViewColumn
                                                Width="160"
                                                DisplayMemberBinding="{Binding StartTime, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}"
                                                Header="開始日時" />
                                            <GridViewColumn
                                                Width="150"
                                                DisplayMemberBinding="{Binding Location}"
                                                Header="場所" />
                                        </ui:GridView>
                                    </ui:ListView.View>
                                </ui:ListView>
                            </StackPanel>
                        </GroupBox>

                        <!--  ニュースグループ  -->
                        <GroupBox Margin="0,0,0,12" Header="ニュース">
                            <StackPanel Margin="4">
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontWeight="SemiBold"
                                    Text="RSSソース" />
                                <ListBox
                                    MaxHeight="120"
                                    Margin="0,0,0,8"
                                    ItemsSource="{Binding RssSources}"
                                    SelectedItem="{Binding SelectedRssSource}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Image
                                                    Width="16"
                                                    Height="16"
                                                    Margin="0,0,4,0"
                                                    Source="{Binding Converter={StaticResource UrlToFaviconConverter}}" />
                                                <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox
                                        Grid.Column="0"
                                        Margin="0,0,8,0"
                                        PlaceholderText="https://example.com/feed.xml"
                                        Text="{Binding NewRssSourceUrl, UpdateSourceTrigger=PropertyChanged}" />
                                    <ui:Button
                                        Grid.Column="1"
                                        Appearance="Primary"
                                        Command="{Binding AddRssSourceCommand}"
                                        Content="追加"
                                        Icon="{ui:SymbolIcon Symbol=Add24}" />
                                </Grid>
                                <ui:Button
                                    Margin="0,0,0,12"
                                    Appearance="Secondary"
                                    Command="{Binding RemoveRssSourceCommand}"
                                    CommandParameter="{Binding SelectedRssSource}"
                                    Content="選択中を削除"
                                    Icon="{ui:SymbolIcon Symbol=Delete24}" />

                                <ui:Button
                                    Margin="0,0,0,8"
                                    Appearance="Secondary"
                                    Command="{Binding FetchNewsCommand}"
                                    Content="ニュース取得" />

                                <TextBlock
                                    Margin="0,4,0,4"
                                    FontWeight="SemiBold"
                                    Text="最新ニューストピック" />
                                <ui:ListView MaxHeight="160" ItemsSource="{Binding RecentNews}">
                                    <ui:ListView.View>
                                        <ui:GridView>
                                            <GridViewColumn Header="アイコン" Width="40">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Image
                                                            Width="16"
                                                            Height="16"
                                                            Source="{Binding FaviconUrl}" />
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn
                                                Width="350"
                                                DisplayMemberBinding="{Binding Title}"
                                                Header="タイトル" />
                                            <GridViewColumn
                                                Width="160"
                                                DisplayMemberBinding="{Binding PublishedAt}"
                                                Header="公開日時" />
                                        </ui:GridView>
                                    </ui:ListView.View>
                                </ui:ListView>
                            </StackPanel>
                        </GroupBox>

                        <ui:Button
                            HorizontalAlignment="Left"
                            Appearance="Primary"
                            Command="{Binding SaveCommand}"
                            Content="設定を保存" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!--  設定タブ  -->
            <TabItem Header="設定">
                <ScrollViewer>
                    <StackPanel Margin="16">
                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="Google AI 設定" />
                        <Label Content="Google AI APIキー" />
                        <ui:PasswordBox Margin="0,0,0,8" Password="{Binding AppConfig.GoogleAiApiKey, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Margin="0,8,0,4"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="プロンプト設定" />
                        <Label Content="ユーザープロンプト（追加の指示）" />
                        <TextBox
                            Height="80"
                            Margin="0,0,0,8"
                            AcceptsReturn="True"
                            Text="{Binding AppConfig.UserPrompt, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto" />

                        <TextBlock
                            Margin="0,8,0,4"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="スケジュール設定" />
                        <Label Content="更新間隔 (時間)" />
                        <TextBox Margin="0,0,0,8" Text="{Binding AppConfig.UpdateIntervalHours, UpdateSourceTrigger=PropertyChanged}" />

                        <CheckBox
                            Margin="0,0,0,12"
                            Content="ログを有効にする"
                            IsChecked="{Binding AppConfig.EnableLogging}" />

                        <ui:CardControl Margin="0,0,0,12" Header="タスクスケジューラ">
                            <ui:CardControl.Icon>
                                <ui:SymbolIcon Symbol="Clock24" />
                            </ui:CardControl.Icon>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Center"
                                    Text="自動実行（更新間隔は上の設定を保存時に適用）" />
                                <CheckBox
                                    VerticalAlignment="Center"
                                    Command="{Binding ToggleTaskSchedulerCommand}"
                                    Content="有効"
                                    IsChecked="{Binding IsTaskSchedulerEnabled}" />
                            </StackPanel>
                        </ui:CardControl>

                        <ui:Button
                            HorizontalAlignment="Left"
                            Appearance="Primary"
                            Command="{Binding SaveCommand}"
                            Content="設定を保存" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</ui:FluentWindow>
