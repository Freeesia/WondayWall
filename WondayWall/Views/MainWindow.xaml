<ui:FluentWindow
    x:Class="WondayWall.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:WondayWall.ViewModels"
    mc:Ignorable="d"
    Title="WondayWall"
    Width="900"
    Height="650"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="WondayWall" />

        <TabControl Grid.Row="1" Margin="8">
            <!-- Home Tab -->
            <TabItem Header="ホーム">
                <ScrollViewer>
                    <StackPanel Margin="16">
                        <ui:CardControl Header="現在の壁紙" Margin="0,0,0,12">
                            <ui:CardControl.Icon>
                                <ui:SymbolIcon Symbol="Image24" />
                            </ui:CardControl.Icon>
                            <Image
                                Source="{Binding LastImagePreviewPath}"
                                MaxHeight="300"
                                Stretch="Uniform" />
                        </ui:CardControl>

                        <ui:CardControl Header="最終実行結果" Margin="0,0,0,12">
                            <ui:CardControl.Icon>
                                <ui:SymbolIcon Symbol="Info24" />
                            </ui:CardControl.Icon>
                            <TextBlock Text="{Binding LastResultMessage}" TextWrapping="Wrap" />
                        </ui:CardControl>

                        <ui:Button
                            Content="壁紙を今すぐ生成"
                            Command="{Binding GenerateCommand}"
                            Appearance="Primary"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,8"
                            Icon="{ui:SymbolIcon Symbol=Wand24}" />

                        <ui:InfoBar
                            IsOpen="{Binding IsGenerating}"
                            Message="壁紙を生成中..."
                            Severity="Informational"
                            IsClosable="False"
                            Margin="0,0,0,12" />

                        <TextBlock Text="実行履歴" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,4" />
                        <ListView ItemsSource="{Binding History}" MaxHeight="200">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="実行日時" Width="160"
                                        DisplayMemberBinding="{Binding ExecutedAt, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}" />
                                    <GridViewColumn Header="成功" Width="60"
                                        DisplayMemberBinding="{Binding IsSuccess}" />
                                    <GridViewColumn Header="メモ / エラー" Width="300"
                                        DisplayMemberBinding="{Binding ErrorSummary}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Data Tab -->
            <TabItem Header="データ">
                <ScrollViewer>
                    <StackPanel Margin="16">
                        <ui:CardControl Header="Googleカレンダー接続状態" Margin="0,0,0,12">
                            <ui:CardControl.Icon>
                                <ui:SymbolIcon Symbol="Calendar24" />
                            </ui:CardControl.Icon>
                            <StackPanel>
                                <TextBlock Text="{Binding CalendarStatus}" Margin="0,0,0,8" />
                                <ui:Button Content="接続確認" Command="{Binding CheckConnectionCommand}" Appearance="Secondary" />
                            </StackPanel>
                        </ui:CardControl>

                        <TextBlock Text="直近のカレンダーイベント" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,4" />
                        <ListView ItemsSource="{Binding RecentEvents}" MaxHeight="160" Margin="0,0,0,12">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="タイトル" Width="250"
                                        DisplayMemberBinding="{Binding Title}" />
                                    <GridViewColumn Header="開始日時" Width="160"
                                        DisplayMemberBinding="{Binding StartTime, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}" />
                                    <GridViewColumn Header="場所" Width="150"
                                        DisplayMemberBinding="{Binding Location}" />
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <ui:CardControl Header="ニュース取得" Margin="0,0,0,12">
                            <ui:CardControl.Icon>
                                <ui:SymbolIcon Symbol="News24" />
                            </ui:CardControl.Icon>
                            <StackPanel>
                                <TextBlock Text="RSSフィードからニュースを取得します" Margin="0,0,0,8" />
                                <ui:Button Content="ニュース取得" Command="{Binding FetchNewsCommand}" Appearance="Secondary" />
                            </StackPanel>
                        </ui:CardControl>

                        <TextBlock Text="最新ニューストピック" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,4" />
                        <ListView ItemsSource="{Binding RecentNews}" MaxHeight="160">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="タイトル" Width="350"
                                        DisplayMemberBinding="{Binding Title}" />
                                    <GridViewColumn Header="取得日時" Width="160"
                                        DisplayMemberBinding="{Binding FetchedAt, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="設定">
                <ScrollViewer>
                    <StackPanel Margin="16">
                        <TextBlock Text="Google AI 設定" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <Label Content="Google AI APIキー" />
                        <TextBox Text="{Binding AppConfig.GoogleAiApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <Label Content="Google AI モデル名" />
                        <TextBox Text="{Binding AppConfig.GoogleAiModelName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                        <TextBlock Text="Googleカレンダー設定" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,4" />
                        <Label Content="OAuth クライアント ID" />
                        <TextBox Text="{Binding AppConfig.GoogleCalendarClientId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <Label Content="OAuth クライアントシークレット" />
                        <TextBox Text="{Binding AppConfig.GoogleCalendarClientSecret, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                        <TextBlock Text="画像設定" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,4" />
                        <Label Content="画像サイズ (例: 1920x1080)" />
                        <TextBox Text="{Binding AppConfig.ImageSize, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <Label Content="画像保存パス" />
                        <TextBox Text="{Binding AppConfig.ImageSavePath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                        <TextBlock Text="スケジュール設定" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,4" />
                        <Label Content="更新間隔 (時間)" />
                        <TextBox Text="{Binding AppConfig.UpdateIntervalHours, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                        <CheckBox
                            Content="ログを有効にする"
                            IsChecked="{Binding AppConfig.EnableLogging}"
                            Margin="0,0,0,12" />

                        <ui:CardControl Header="タスクスケジューラ" Margin="0,0,0,12">
                            <ui:CardControl.Icon>
                                <ui:SymbolIcon Symbol="Clock24" />
                            </ui:CardControl.Icon>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="自動実行（更新間隔は上の設定を保存時に適用）" VerticalAlignment="Center" Margin="0,0,16,0" />
                                <CheckBox
                                    Content="有効"
                                    IsChecked="{Binding IsTaskSchedulerEnabled}"
                                    Command="{Binding ToggleTaskSchedulerCommand}"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:CardControl>

                        <ui:Button
                            Content="設定を保存"
                            Command="{Binding SaveCommand}"
                            Appearance="Primary"
                            HorizontalAlignment="Left" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</ui:FluentWindow>
